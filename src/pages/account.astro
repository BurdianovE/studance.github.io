---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Личный кабинет — Studance" description="Личный кабинет школы танца Studance">
  <section class="account">
    <div class="container account__container">
      <div class="account__card" id="accountApp">
        <!-- Здесь будет отображаться интерфейс через JavaScript -->
      </div>
    </div>
  </section>
</Layout>

<style>
.account {
  min-height: calc(100vh - 72px - 260px);
  padding: 56px 0 80px;
  background: var(--off-white);
}

.account__container {
  max-width: 520px;
}

.account__card {
  background: var(--white);
  border-radius: 24px;
  padding: 48px 44px;
  box-shadow: 0 20px 60px rgba(26, 58, 74, 0.11);
  transition: all 0.3s ease;
}

/* Текст и общие стили */
.account__title {
  font-family: var(--font-display);
  font-size: clamp(24px, 4vw, 32px);
  font-weight: 900;
  color: var(--teal);
  letter-spacing: -0.03em;
  margin-bottom: 6px;
}

.account__subtitle {
  font-size: 15px;
  color: var(--gray);
  margin-bottom: 28px;
  line-height: 1.6;
}

/* Tabs */
.account__tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 28px;
  background: rgba(26, 58, 74, 0.06);
  border-radius: 12px;
  padding: 4px;
}

.account__tab {
  flex: 1;
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 600;
  font-family: var(--font-display);
  color: var(--teal);
  border-radius: 10px;
  transition: all 0.3s ease;
  cursor: pointer;
  border: none;
  background: transparent;
  letter-spacing: 0.02em;
}

.account__tab.is-active {
  background: var(--white);
  box-shadow: 0 2px 12px rgba(26, 58, 74, 0.12);
}

.account__tab:hover:not(.is-active) {
  background: rgba(26, 58, 74, 0.04);
}

/* Form */
.account__form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.account__field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.account__label {
  font-size: 13px;
  font-weight: 700;
  color: var(--teal);
  letter-spacing: 0.03em;
  font-family: var(--font-display);
}

.account__input {
  padding: 14px 18px;
  border: 2px solid rgba(26, 58, 74, 0.12);
  border-radius: 12px;
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--text);
  outline: none;
  transition: all 0.3s ease;
  background: var(--white);
}

.account__input:focus {
  border-color: var(--yellow);
  box-shadow: 0 0 0 4px rgba(245, 200, 0, 0.15);
}

.account__input::placeholder {
  color: rgba(26, 58, 74, 0.3);
}

.account__submit {
  margin-top: 10px;
  padding: 16px 28px;
  background: var(--teal);
  color: var(--white);
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  border: none;
  border-radius: 50px;
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
  cursor: pointer;
}

.account__submit:hover:not(:disabled) {
  background: #0d2535;
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(26, 58, 74, 0.25);
}

.account__submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Status messages */
.account__status {
  min-height: 20px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  border-radius: 10px;
  padding: 0;
  transition: all 0.3s ease;
}

.account__status.is-ok {
  color: #15803d;
  background: #f0fdf4;
  padding: 12px 16px;
  border-left: 4px solid #15803d;
}

.account__status.is-err {
  color: #b91c1c;
  background: #fef2f2;
  padding: 12px 16px;
  border-left: 4px solid #b91c1c;
}

/* Profile */
.account__profile {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.account__profile-header {
  display: flex;
  align-items: center;
  gap: 20px;
}

.account__profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--yellow);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 900;
  color: var(--teal);
  flex-shrink: 0;
}

.account__profile-info {
  flex: 1;
}

.account__user-name {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  color: var(--teal);
  margin-bottom: 4px;
}

.account__user-email {
  font-size: 14px;
  color: var(--gray);
}

.account__meta {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--teal);
  padding: 16px 20px;
  background: rgba(245, 200, 0, 0.12);
  border-radius: 12px;
  border-left: 4px solid var(--yellow);
  font-weight: 500;
}

.account__meta svg {
  flex-shrink: 0;
}

.account__divider {
  border: none;
  border-top: 2px solid rgba(26, 58, 74, 0.08);
  margin: 4px 0;
}

.account__actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.account__link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 16px 24px;
  background: var(--yellow);
  color: var(--teal);
  font-weight: 700;
  font-family: var(--font-display);
  font-size: 14px;
  letter-spacing: 0.02em;
  border-radius: 50px;
  transition: all 0.3s ease;
  text-decoration: none;
  border: none;
}

.account__link:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(245, 200, 0, 0.35);
}

.account__logout {
  padding: 14px;
  font-size: 14px;
  font-weight: 600;
  color: var(--gray);
  background: none;
  border: 2px solid rgba(26, 58, 74, 0.1);
  border-radius: 50px;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
  font-family: var(--font-display);
  letter-spacing: 0.02em;
}

.account__logout:hover {
  color: var(--teal);
  border-color: var(--teal);
  background: rgba(26, 58, 74, 0.04);
}

/* Spinner */
.account__spinner {
  display: flex;
  justify-content: center;
  padding: 40px 0;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(26, 58, 74, 0.1);
  border-top-color: var(--yellow);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Responsive */
@media (max-width: 540px) {
  .account__card {
    padding: 32px 24px;
    border-radius: 20px;
  }

  .account__profile-header {
    flex-direction: column;
    text-align: center;
  }

  .account__profile-avatar {
    width: 80px;
    height: 80px;
    font-size: 34px;
  }

  .account__meta {
    font-size: 13px;
    padding: 14px 16px;
  }
}
</style>

<script>
type User = { id: string; email: string; name: string; createdAt: string };

const app = document.getElementById('accountApp');
let activeTab: 'login' | 'register' = 'login';

function escHtml(s: string) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function fmtDate(iso: string) {
  try { 
    const date = new Date(iso);
    return date.toLocaleDateString('ru-RU', { day:'numeric', month:'long', year:'numeric' });
  } catch { return iso; }
}

function setStatus(el: HTMLElement | null, text: string, kind?: 'ok'|'err') {
  if (!el) return;
  el.textContent = text;
  el.className = 'account__status' + (kind ? ` is-${kind}` : '');
}

function renderAuth() {
  if (!app) return;
  app.innerHTML = `
    <h1 class="account__title">Добро пожаловать</h1>
    <p class="account__subtitle">Войдите в аккаунт или создайте новый</p>
    <div class="account__tabs" role="tablist">
      <button type="button" class="account__tab${activeTab==='login'?' is-active':''}" data-tab="login">Вход</button>
      <button type="button" class="account__tab${activeTab==='register'?' is-active':''}" data-tab="register">Регистрация</button>
    </div>
    <form class="account__form" id="authForm" novalidate>
      ${activeTab==='register' ? `
      <div class="account__field">
        <label class="account__label" for="auth-name">Ваше имя</label>
        <input class="account__input" id="auth-name" name="name" type="text" autocomplete="name" placeholder="Например, Екатерина" />
      </div>` : ''}
      <div class="account__field">
        <label class="account__label" for="auth-email">Email</label>
        <input class="account__input" id="auth-email" name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
      </div>
      <div class="account__field">
        <label class="account__label" for="auth-password">Пароль</label>
        <input class="account__input" id="auth-password" name="password" type="password" autocomplete="${activeTab==='login'?'current-password':'new-password'}" minlength="6" placeholder="Минимум 6 символов" required />
      </div>
      <p class="account__status" id="authStatus" role="status" aria-live="polite"></p>
      <button type="submit" class="account__submit" id="authSubmit">
        ${activeTab==='login' ? 'Войти в аккаунт' : 'Создать аккаунт'}
      </button>
    </form>`;

  app.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab as 'login'|'register';
      if (tab && tab !== activeTab) { activeTab = tab; renderAuth(); }
    });
  });

  const form = document.getElementById('authForm') as HTMLFormElement|null;
  const statusEl = document.getElementById('authStatus');
  const submitBtn = document.getElementById('authSubmit') as HTMLButtonElement|null;

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    if (!form || !submitBtn) return;
    const fd = new FormData(form);
    const email = String(fd.get('email') ?? '').trim();
    const password = String(fd.get('password') ?? '');
    const name = String(fd.get('name') ?? '').trim();

    if (!email.includes('@')) { setStatus(statusEl, 'Пожалуйста, введите корректный email', 'err'); return; }
    if (password.length < 6) { setStatus(statusEl, 'Пароль должен содержать минимум 6 символов', 'err'); return; }
    if (activeTab === 'register' && !name) { setStatus(statusEl, 'Пожалуйста, укажите ваше имя', 'err'); return; }

    const endpoint = activeTab === 'login' ? '/api/auth/login' : '/api/auth/register';
    const body = activeTab === 'login' ? { email, password } : { email, password, name };

    submitBtn.disabled = true;
    const prev = submitBtn.textContent;
    submitBtn.textContent = 'Подождите...';
    setStatus(statusEl, '');

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json; charset=utf-8' },
        credentials: 'same-origin',
        body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { 
        setStatus(statusEl, data.error || 'Ошибка авторизации. Попробуйте снова.', 'err'); 
        return; 
      }
      renderProfile(data.user as User);
    } catch {
      setStatus(statusEl, 'Проблема с подключением. Проверьте интернет.', 'err');
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = prev; }
    }
  });
}

function renderProfile(user: User) {
  if (!app) return;
  const initial = (user.name?.[0] ?? user.email?.[0] ?? '?').toUpperCase();
  
  app.innerHTML = `
    <div class="account__profile">
      <div class="account__profile-header">
        <div class="account__profile-avatar">${escHtml(initial)}</div>
        <div class="account__profile-info">
          <h1 class="account__user-name">${escHtml(user.name)}</h1>
          <p class="account__user-email">${escHtml(user.email)}</p>
        </div>
      </div>
      
      <div class="account__meta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Аккаунт создан ${fmtDate(user.createdAt)}
      </div>
      
      <hr class="account__divider" />
      
      <div class="account__actions">
        <a href="/#signup" class="account__link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Записаться на занятие
        </a>
        <button type="button" class="account__logout" id="logoutBtn">Выйти из аккаунта</button>
      </div>
    </div>`;

  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    try { 
      await fetch('/api/auth/logout', { method:'POST', credentials:'same-origin' }); 
    } catch { /* ignore */ }
    activeTab = 'login';
    renderAuth();
  });
}

async function init() {
  try {
    const res = await fetch('/api/auth/me', { credentials: 'same-origin' });
    if (res.ok) {
      const data = await res.json();
      if (data.user) { 
        renderProfile(data.user as User); 
        return; 
      }
    }
  } catch { /* show login */ }
  renderAuth();
}

// Запускаем при загрузке
init();
</script>