---
import Layout from '../layouts/Layout.astro';
---

<Layout title="О нас — Studance">
  <section class="about-page">
    <div class="container">
      <h1 class="about-page__title">О нас</h1>
      <p class="about-page__text">Страница в разработке.</p>
    </div>
  </section>
</Layout>

<style>
.about-page {
  min-height: 60vh;
  padding: 64px 0;
  background: var(--off-white);
}

.about-page__title {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 900;
  color: var(--teal);
  margin-bottom: 16px;
  letter-spacing: -0.03em;
}

.about-page__text {
  color: var(--gray);
  font-size: 16px;
}
</style>
