---
---

<section class="reviews" id="reviews">
  <div class="container">
    <div class="reviews__header">
      <div class="reviews__title-block">
        <h2 class="reviews__title">Отзывы учеников</h2>
        <p class="reviews__sub">Что говорят о нас на Яндекс Картах</p>
      </div>
      <a
        href="https://yandex.ru/maps/org/34399434443/reviews?reviews%5BpublicId%5D=ekgwdt68m15pqazh6zfpqujn6m&si=66bu812jwtwazdmk9fzwdtcpng&utm_source=review"
        target="_blank"
        rel="noopener noreferrer"
        class="reviews__ya-link"
        aria-label="Все отзывы на Яндекс Картах"
      >
        <svg class="reviews__ya-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="16" fill="#FC3F1D"/>
          <path d="M18.04 8H15.26C12.5 8 10.96 9.34 10.96 11.58C10.96 13.56 11.86 14.68 13.6 15.88L10.5 21H13.04L16.38 15.56H17.2V21H19.54V8H18.04ZM17.2 13.7H16.24C14.74 13.7 14.04 13.02 14.04 11.66C14.04 10.3 14.82 9.82 16.3 9.82H17.2V13.7Z" fill="white"/>
        </svg>
        <span>Все отзывы</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>

    <!-- Rating summary -->
    <div class="reviews__rating-bar">
      <div class="reviews__rating-score">
        <span class="reviews__score-num">5.0</span>
        <div class="reviews__stars" aria-label="5.0 звезды из 5">
          {[1,2,3,4,5].map(i => (
            <svg width="20" height="20" viewBox="0 0 24 24" fill={i <= 5 ? '#FC3F1D' : 'none'} stroke="#FC3F1D" stroke-width="1.5">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <span class="reviews__score-count">34 отзыва</span>
      </div>
      <div class="reviews__rating-bars">
        {([
          { stars: 5, pct: 100 },
          { stars: 4, pct: 0  },
          { stars: 3, pct: 0  },
          { stars: 2, pct: 0  },
          { stars: 1, pct: 0  },
        ]).map(row => (
          <div class="reviews__bar-row">
            <span class="reviews__bar-label">{row.stars}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#FC3F1D" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <div class="reviews__bar-track">
              <div class="reviews__bar-fill" style={`width:${row.pct}%`}></div>
            </div>
            <span class="reviews__bar-pct">{row.pct}%</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Cards slider -->
    <div class="reviews__slider" data-reviews-slider>
      <button class="reviews__arrow reviews__arrow--prev" aria-label="Предыдущие отзывы">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="reviews__viewport">
        <div class="reviews__track">

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#F5C800">М</div>
              <div>
                <div class="review-card__name">Марина К.</div>
                <div class="review-card__date">24 сентября 2024</div>
              </div>
              <div class="review-card__stars" aria-label="5 звёзд">
                {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Прошлый учебный год дочка ходила на хип-хоп на Садовом.
Было очень любопытно и приятно наблюдать за творческим ростом ребенка - от двух притопов к выступлению на сцене. Спасибо преподавателю Дарье за занятия, на которые дочка ходила с большим удовольствием!</p>
          </article>

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#FF6B6B;color:#fff">А</div>
              <div>
                <div class="review-card__name">арина</div>
                <div class="review-card__date">1 ноября 2024</div>
              </div>
              <div class="review-card__stars" aria-label="5 звёзд">
                {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Это прекрасная школа танца! Хорошие и опытные тренера. Прекрасные администраторы! Много разных направлений, много занятий и можно выбрать то чем хотите заняться именно вы! Занятия и для взрослых, и для детей. Я занимаюсь в этой школе с самого открытия и всё очень круто! Отдельное и огромное спасибо тренерам Наталье Евгеньевне, Анне Михайловне и Полине Дмитриевне 💓! А также прекрасному администратору Вике💋</p>
          </article>

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#7EC8C8">Е</div>
              <div>
                <div class="review-card__name">Елена Шевченко</div>
                <div class="review-card__date">10 января 2024</div>
              </div>
              <div class="review-card__stars" aria-label="5 звёзд">
                {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Я очень люблю эту Школу❤️
Посещаю её второй год. Здесь очень сильная Команда Профессионалов, любящих свою работу, горящих своим делом и с большой любовью к Студентам.
У меня здесь занимаются дети, и сама я посещаю тренировки.
Очень люблю Зумбу, бачату, бальные танцы, собираюсь посетить джас-фанк.</p>
          </article>

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#FF9F40">О</div>
              <div>
                <div class="review-card__name">Егор Д.</div>
                <div class="review-card__date">25 июня 2025</div>
              </div>
              <div class="review-card__stars" aria-label="5 звёзд">
                {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Превосходный преподаватель Анна, отличная школа, персонал и ремонт. Очень высокий уровень для г. Реутов :)) советую друзьям данного хореографа, познакомился с хорошими людьми, рекомендую</p>
          </article>

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#C8A2C8">Т</div>
              <div>
                <div class="review-card__name">Кристина Викторовна</div>
                <div class="review-card__date">5 июля 2024</div>
              </div>
              <div class="review-card__stars" aria-label="4 звезды">
                {'★★★★★'.split('').map((s,i) => <span class={`star${i===4?' star--empty':''}`}>{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Классный коллектив. И преподаватели и администраторы. Чистые,светлые залы. Радует возможность взять зал в аренду.
За группу бальных танцев для взрослых отдельное спасибо!!!</p>
          </article>

          <article class="review-card">
            <div class="review-card__top">
              <div class="review-card__avatar" style="background:#2A5060;color:#F5C800">Д</div>
              <div>
                <div class="review-card__name">Alex L.</div>
                <div class="review-card__date">10 января 2024</div>
              </div>
              <div class="review-card__stars" aria-label="5 звёзд">
                {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
              </div>
            </div>
            <p class="review-card__text">Студия танцев для детей STUDANCE - прекрасное место, где мои дети раскрывают свой танцевальный потенциал (и не только его: там много разных направлений помимо основного танцевального)! Профессиональные тренеры создают теплую и поощрительную атмосферу, вдохновляя малышей на творчество и самовыражение.</p>
          </article>

        </div>
      </div>

      <button class="reviews__arrow reviews__arrow--next" aria-label="Следующие отзывы">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="reviews__footer">
      <a
        href="https://yandex.ru/maps/org/34399434443/reviews?reviews%5BpublicId%5D=ekgwdt68m15pqazh6zfpqujn6m&si=66bu812jwtwazdmk9fzwdtcpng&utm_source=review"
        target="_blank"
        rel="noopener noreferrer"
        class="reviews__all-btn"
      >
        Читать все отзывы на Яндекс Картах
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
.reviews {
  background: var(--off-white);
  padding: 80px 0;
}

.reviews__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.reviews__title {
  font-family: var(--font-display);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--teal);
  letter-spacing: -0.02em;
  margin-bottom: 6px;
}

.reviews__sub {
  color: var(--gray);
  font-size: 15px;
}

.reviews__ya-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border: 1.5px solid rgba(26,58,74,0.15);
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  color: var(--teal);
  white-space: nowrap;
  transition: border-color var(--transition), background var(--transition);
  flex-shrink: 0;
}

.reviews__ya-link:hover {
  border-color: var(--teal);
  background: var(--white);
}

.reviews__ya-icon {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

/* Rating summary */
.reviews__rating-bar {
  display: flex;
  align-items: center;
  gap: 40px;
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 28px 32px;
  margin-bottom: 40px;
  box-shadow: var(--shadow-sm);
  flex-wrap: wrap;
}

.reviews__rating-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  min-width: 120px;
}

.reviews__score-num {
  font-family: var(--font-display);
  font-size: 52px;
  font-weight: 900;
  color: var(--teal);
  line-height: 1;
  letter-spacing: -0.03em;
}

.reviews__stars {
  display: flex;
  gap: 3px;
}

.reviews__score-count {
  font-size: 13px;
  color: var(--gray);
}

.reviews__rating-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 200px;
}

.reviews__bar-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.reviews__bar-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--teal);
  width: 12px;
  text-align: right;
}

.reviews__bar-track {
  flex: 1;
  height: 8px;
  background: var(--gray-light);
  border-radius: 4px;
  overflow: hidden;
}

.reviews__bar-fill {
  height: 100%;
  background: #FC3F1D;
  border-radius: 4px;
  transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

.reviews__bar-pct {
  font-size: 12px;
  color: var(--gray);
  width: 30px;
}

/* Slider */
.reviews__slider {
  display: grid;
  grid-template-columns: 48px 1fr 48px;
  gap: 14px;
  align-items: center;
}

.reviews__viewport {
  overflow: hidden;
}

.reviews__track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(300px, 380px);
  gap: 16px;
  transition: transform var(--transition);
}

.reviews__arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--white);
  color: var(--teal);
  box-shadow: var(--shadow-sm);
  transition: background var(--transition), color var(--transition), opacity var(--transition);
  flex-shrink: 0;
}

.reviews__arrow:hover {
  background: var(--yellow);
}

.reviews__arrow:disabled {
  opacity: 0.3;
  pointer-events: none;
}

/* Review card */
.review-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition), box-shadow var(--transition);
}

.review-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}

.review-card__top {
  display: flex;
  align-items: center;
  gap: 12px;
}

.review-card__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--teal);
  flex-shrink: 0;
}

.review-card__name {
  font-weight: 600;
  font-size: 15px;
  color: var(--teal);
}

.review-card__date {
  font-size: 12px;
  color: var(--gray);
  margin-top: 2px;
}

.review-card__stars {
  margin-left: auto;
  display: flex;
  gap: 1px;
}

.star {
  color: #FC3F1D;
  font-size: 16px;
  line-height: 1;
}

.star--empty {
  color: var(--gray-light);
}

.review-card__text {
  font-size: 14px;
  line-height: 1.7;
  color: #444;
}

/* Footer */
.reviews__footer {
  margin-top: 36px;
  text-align: center;
}

.reviews__all-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  background: var(--white);
  border: 2px solid var(--teal);
  color: var(--teal);
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  border-radius: 50px;
  transition: background var(--transition), color var(--transition), transform var(--transition);
}

.reviews__all-btn:hover {
  background: var(--teal);
  color: var(--white);
  transform: translateY(-2px);
}

@media (max-width: 820px) {
  .reviews__slider {
    grid-template-columns: 40px 1fr 40px;
    gap: 8px;
  }

  .reviews__track {
    grid-auto-columns: min(100%, 340px);
  }

  .reviews__rating-bar {
    gap: 24px;
    padding: 20px 24px;
  }
}

@media (max-width: 560px) {
  .reviews__track {
    grid-auto-columns: 100%;
  }
}
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-reviews-slider]').forEach((slider) => {
    const viewport = slider.querySelector<HTMLElement>('.reviews__viewport');
    const track = slider.querySelector<HTMLElement>('.reviews__track');
    const prev = slider.querySelector<HTMLButtonElement>('.reviews__arrow--prev');
    const next = slider.querySelector<HTMLButtonElement>('.reviews__arrow--next');
    if (!viewport || !track || !prev || !next) return;

    const pageSize = () => (window.innerWidth <= 560 ? 1 : window.innerWidth <= 900 ? 2 : 3);
    let current = 0;

    const cards = () => Array.from(track.querySelectorAll<HTMLElement>('.review-card'));
    const maxPage = () => Math.max(0, cards().length - pageSize());

    const update = () => {
      const first = cards()[0];
      if (!first) return;
      const gap = 16;
      const cardWidth = first.getBoundingClientRect().width + gap;
      track.style.transform = `translateX(-${current * cardWidth}px)`;
      prev.disabled = current <= 0;
      next.disabled = current >= maxPage();
    };

    prev.addEventListener('click', () => { current = Math.max(0, current - 1); update(); });
    next.addEventListener('click', () => { current = Math.min(maxPage(), current + 1); update(); });
    window.addEventListener('resize', () => { current = Math.min(current, maxPage()); update(); });
    update();
  });
</script>
