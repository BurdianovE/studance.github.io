---
import type { Teacher } from '../lib/cms';

interface Props {
  teachers: Teacher[];
}

const { teachers } = Astro.props;

const colors = ['#F5C800', '#2A5060', '#FF9F40', '#7EC8C8'];
---

<section class="teachers" id="teachers">
  <div class="container">
    <div class="teachers__header">
      <h2 class="teachers__title">Наши преподаватели</h2>
      <p class="teachers__sub">Профессиональные хореографы с многолетним опытом</p>
    </div>

    <div class="teachers__slider" data-teachers-slider>
      <button class="teachers__arrow teachers__arrow--prev" aria-label="Предыдущие преподаватели">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <div class="teachers__viewport">
        <div class="teachers__track">
          {teachers.map((t, i) => {
            const color = colors[i % colors.length];
            return (
              <article class="teacher-card">
            <div
              class="teacher-card__avatar"
              style={`background: ${color}22; --color: ${color}`}
            >
              {t.photoUrl ? (
                <img class="teacher-card__photo" src={t.photoUrl} alt="" loading="lazy" />
              ) : (
                <>
                  <div class="teacher-card__shape"></div>
                  <span class="teacher-card__initial">{t.name[0] ?? '?'}</span>
                </>
              )}
            </div>
            <div class="teacher-card__info">
              <h3 class="teacher-card__name">{t.name}</h3>
              <p class="teacher-card__role">{t.role}</p>
              {t.experience && (
                <span class="teacher-card__exp">{t.experience} опыта</span>
              )}
            </div>
              </article>
            );
          })}
        </div>
      </div>
      <button class="teachers__arrow teachers__arrow--next" aria-label="Следующие преподаватели">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
.teachers {
  padding: 80px 0;
  background: var(--white);
}

.teachers__header {
  margin-bottom: 48px;
}

.teachers__title {
  font-family: var(--font-display);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--teal);
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.teachers__sub {
  color: var(--gray);
  font-size: 16px;
}

.teachers__slider {
  display: grid;
  grid-template-columns: 48px 1fr 48px;
  gap: 14px;
  align-items: center;
}

.teachers__viewport {
  overflow: hidden;
}

.teachers__track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(220px, 1fr);
  gap: 16px;
  transition: transform var(--transition);
}

.teachers__arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--off-white);
  color: var(--teal);
  transition: background var(--transition), color var(--transition), opacity var(--transition);
}

.teachers__arrow:hover {
  background: var(--yellow);
}

.teachers__arrow:disabled {
  opacity: 0.3;
  pointer-events: none;
}

.teacher-card {
  background: var(--off-white);
  border-radius: var(--radius-lg);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  transition: transform var(--transition), box-shadow var(--transition);
}

.teacher-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(26, 58, 74, 0.1);
}

.teacher-card__avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.teacher-card__photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 2;
}

.teacher-card__shape {
  position: absolute;
  inset: 0;
  background: var(--color, var(--yellow));
  opacity: 0.25;
  border-radius: 50%;
}

.teacher-card__initial {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 900;
  color: var(--teal);
  position: relative;
  z-index: 1;
}

.teacher-card__name {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--teal);
  letter-spacing: -0.01em;
}

.teacher-card__role {
  font-size: 14px;
  color: var(--gray);
  margin-top: 2px;
}

.teacher-card__exp {
  display: inline-block;
  background: var(--yellow);
  color: var(--teal);
  font-size: 12px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 50px;
  margin-top: 4px;
}

@media (max-width: 900px) {
  .teachers__slider {
    grid-template-columns: 40px 1fr 40px;
    gap: 8px;
  }
}

@media (max-width: 640px) {
  .teachers__track {
    grid-auto-columns: 100%;
  }
}
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-teachers-slider]').forEach((slider) => {
    const viewport = slider.querySelector<HTMLElement>('.teachers__viewport');
    const track = slider.querySelector<HTMLElement>('.teachers__track');
    const prev = slider.querySelector<HTMLButtonElement>('.teachers__arrow--prev');
    const next = slider.querySelector<HTMLButtonElement>('.teachers__arrow--next');
    if (!viewport || !track || !prev || !next) return;

    const pageSize = () => (window.innerWidth <= 640 ? 1 : window.innerWidth <= 980 ? 2 : 4);
    let current = 0;

    const cards = () => Array.from(track.querySelectorAll<HTMLElement>('.teacher-card'));
    const maxPage = () => Math.max(0, cards().length - pageSize());

    const update = () => {
      const first = cards()[0];
      if (!first) return;
      const gap = 16;
      const cardWidth = first.getBoundingClientRect().width + gap;
      track.style.transform = `translateX(-${current * cardWidth}px)`;
      prev.disabled = current <= 0;
      next.disabled = current >= maxPage();
    };

    prev.addEventListener('click', () => {
      current = Math.max(0, current - 1);
      update();
    });

    next.addEventListener('click', () => {
      current = Math.min(maxPage(), current + 1);
      update();
    });

    window.addEventListener('resize', () => {
      current = Math.min(current, maxPage());
      update();
    });

    update();
  });
</script>
